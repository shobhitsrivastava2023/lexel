# Optional: Fish Audio + Gemini for /voice-agent (realtime TTS + voice chat)
# FISH_API_KEY=
# GEMINI_API_KEY=
# FISH_TTS_BACKEND=s1
# FISH_TTS_PCM_SAMPLE_RATE=24000
# FISH_TTS_CHUNK_LENGTH=72
# Model id from Google AI Studio. If you see 429 / quota errors on free tier, try another
# model (e.g. gemini-1.5-flash-8b) or enable billing for your API key.
# GEMINI_MODEL=gemini-2.0-flash
# Optional: for Multilingual voice (23 languages). Deploy chatterbox_multilingual_tts.py on Modal.
# CHATTERBOX_MULTILINGUAL_API_URL=
HF_ACCESS_TOKEN=

# Optional: Translation provider for Live Translation panel (speech is still browser Web Speech API)
# libretranslate = self-hosted LibreTranslate (default URL http://localhost:5000). API key optional locally.
# If you use --load-only en,es,fr, set LIBRETRANSLATE_LANGUAGE_IDS=en,es,fr to match the UI and validation.
# TRANSLATE_PROVIDER=libretranslate
# LIBRETRANSLATE_URL=http://localhost:5000
# LIBRETRANSLATE_LANGUAGE_IDS=en,es,fr
# LIBRETRANSLATE_API_KEY=
# google = Google Cloud Translation API
# TRANSLATE_PROVIDER=google
# GOOGLE_TRANSLATE_API_KEY=your-google-api-key
# deepl = DeepL
# TRANSLATE_PROVIDER=deepl
# TRANSLATE_DEEPL_API_KEY=your-deepl-api-key

